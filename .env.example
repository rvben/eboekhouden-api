# API_KEY=choose-a-secret-here  # optional — if unset, auth is disabled
EBOEKHOUDEN_USERNAME=your-username
EBOEKHOUDEN_PASSWORD=your-password

# READONLY=true              # disable write endpoints (create offerte/relatie, status change, email)

# Required for docker-compose cloudflared service
# TUNNEL_TOKEN=your-cloudflare-tunnel-token

# Deployment (optional, used by make deploy)
# HOST=root@your-server
